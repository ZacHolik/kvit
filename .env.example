# P2-6: early adopter / referral price lock UI (dashboard, alati, postavke)
# false = sakriveno; true = prikazuje price lock hook (samo uz marketing odobrenje)
NEXT_PUBLIC_PRICE_LOCK_FEATURE=false

# App (URL u pregledniku; npr. https://app.kvik.online za deploy)
# getSiteUrl() za SEO/OG/JSON-LD mapira app.kvik.online → https://kvik.online
NEXT_PUBLIC_APP_URL="https://kvik.online"

# Supabase (projekt → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (AI asistent)
ANTHROPIC_API_KEY=

# Resend — API ključ za vlastite službene emailove (npr. transakcijski).
# Za Supabase Auth (potvrda registracije): u Supabase Dashboard → Authentication
# → Emails → SMTP Settings uključi Custom SMTP i unesi Resend podatke:
#   Host: smtp.resend.com
#   Port: 465 (SSL) ili 587 (TLS)
#   User: resend
#   Password: <RESEND_API_KEY>
#   Sender: noreply@kvik.online (domena mora biti verificirana u Resendu)
# Redirect URLs: dodaj https://kvik.online/auth/callback (i http://localhost:3000/auth/callback za dev)
RESEND_API_KEY=

# Cloudflare Turnstile (opcionalno — registracija): https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Fiskalizacija — AES-256-GCM enkripcija za FINA certifikate
# Generiraj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Postavi i na Vercelu (Production + Preview) kao FISCAL_ENCRYPTION_KEY
FISCAL_ENCRYPTION_KEY=

# FINA okruženje: test (cistest) ili production (porezna-uprava)
FINA_ENV=test
FINA_CA_CERT_BASE64_TEST=
FINA_CA_CERT_BASE64_PROD=

# CIS SOAP endpoint (opcionalni override; inače ovisi o FINA_ENV)
CIS_URL=

# TLS: FINA / CIS puni CA lanac (Node ne vjeruje demo CA bez ovoga)
# Legacy fallback ako TEST nije postavljen
FINA_CA_CERT_BASE64=
# Lokalno: putanja do PEM-a; ako prazno, čita se certs/fina_full_chain.pem (vidi certs/README.md)
FINA_CA_CERT_PATH=

# Cloud Run CIS proxy (Vercel prod) — ako postavljen, SOAP ide kroz proxy umjesto direktno
# Lokalno: ostavi prazno i koristi FINA_CA_CERT_PATH / certs/fina_full_chain.pem
CIS_PROXY_URL=https://kvik-cis-proxy-1051763023473.europe-west3.run.app
CIS_PROXY_SECRET=kvik-cis-60be98ec7d4410c812875e7270ff884a

# Vercel Cron: GET /api/fiscal/retry/cron s Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Samo NEXT_PUBLIC_ prefiks — koristi se na klijentu za @stripe/stripe-js loadStripe()
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook endpoint secret — Stripe Dashboard → Webhooks → Signing secret
# Dev (Stripe CLI): stripe listen --forward-to localhost:3000/api/stripe/webhook
# Prod (Vercel):    https://kvik.online/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID-jevi — Stripe Dashboard → Products → Kvik Pausalist
# Isti produkt, dva Price objekta (monthly / yearly)
STRIPE_PRICE_MONTHLY=price_...   # 7,00 EUR / month
STRIPE_PRICE_YEARLY=price_...    # 67,20 EUR / year  (= 5,60 EUR/mj)

# Opcionalno: test-mode ključevi za lokalni razvoj
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=price_...
# STRIPE_PRICE_YEARLY=price_...

# Kvik kao izdavatelj pretplatničkog računa (R1 ako je OIB postavljen, inače R2)
KVIK_BILLING_OIB=99856845561
KVIK_BILLING_NAZIV=KVIK, vl. Željko Holik
KVIK_BILLING_ADRESA=Poljana Josipa Brunšmida 8, 10000 Zagreb

# Resend — From adrese po tipu poruke
RESEND_FROM_BILLING=Kvik Naplata <pretplata@kvik.hr>
RESEND_FROM_SUPPORT=Kvik Podrška <podrska@kvik.hr>
RESEND_FROM_NOREPLY=Kvik <noreply@kvik.online>
