{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "crons": [
    {
      "path": "/api/fiscal/retry/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/stripe/billing/cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/fina-cert-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/fina-cert-check",
      "schedule": "0 8 * * *"
    }
  ],
  "functions": {
    "src/app/api/racuni/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/fiscal/certificate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/fiscal/certificate/validate/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/fiscal/retry/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}